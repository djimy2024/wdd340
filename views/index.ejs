<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- title %> | CSE 340 App</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <header>
        <div class="header-container">
          <span class="siteName">
            <a href="/" title="Return to home page">CSE Motors</a>
          </span>
          <div id="tools">
            <a title="Click to log in" href="/account/login">My Account</a>
          </div>
        </div>
      </header>
  <nav>
    <ul class="nav-bar">
      <li><a href="#">Home</a></li>
      <li><a href="#">Custom</a></li>
      <li><a href="#">Sedan</a></li>
      <li><a href="#">SUV</a></li>
      <li><a href="#">Truck</a></li>
    </ul>
  </nav>

  <main>
    <section class="hero-section">
      <div class="image-container">
        <img src="/images/vehicles/delorean.jpg" alt="Delorean car">
        <div class="car-info-overlay">
          <h2>DMC Delorean</h2>
          <ul>
            <li>3 Cup holders</li>
            <li>Superman doors</li>
            <li>Fuzzy dice!</li>
          </ul>
          <a href="#" class="own-button">Own today</a>
        </div>
      </div>
    </section>

    <div class="upgrade-review-wrapper">
    <section class="upgrades-section">
        <h2>Delorean Upgrades</h2>
        <div class="upgrade-gallery">
          <figure>
              <img src="/images/upgrades/flame.jpg" alt="flames">
              <figcaption><a href="#">Flames Decals</a></figcaption>
          </figure>
          <figure>
              <img src="/images/upgrades/hub-cap.jpg" alt="hub">
              <figcaption><a href="#">Hubs Caps</a></figcaption>
          </figure>
          <figure>
              <img src="/images/upgrades/flux-cap.png" alt="flux">
              <figcaption><a href="#">Flux Capacitor</a></figcaption>
          </figure>
          <figure>
              <img src="/images/upgrades/bumper_sticker.jpg" alt="bumper">
              <figcaption><a href="#">Bumper Stickers</a></figcaption>
          </figure> 
        </div>
    </section>
  
    <section class="reviews-section">
        <h2>DMC Delorean Reviews</h2>
        <ul class="review-list">
            <li>"So fast it's almost like travelling in time." 4/5</li>
            <li>"Coolest ride on the road." 4/5</li>
            <li>"I'm feeling McFly!" 5/5</li>
            <li>"The most futuristic ride of our day." 4.5/5</li>
            <li>"80's livin and I love it!" 5/5</li>
        </ul>
    </section>
    </div>
  </main>
      
<footer><p>&copy; 2023, CSE 340 App</p></footer>
</body>
</html>